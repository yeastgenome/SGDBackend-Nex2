# prod.sh.example — template for the prod runtime env file sourced by start.sh.
#
# Copy to prod.sh on the prod host (sgd-curate) and fill in real values. prod.sh
# is gitignored because it holds secrets (DB/ES URIs, AWS + S3 keys, Pusher/
# Google secrets, login credentials) — NEVER commit the filled-in file.
#
#   cp prod.sh.example prod.sh && $EDITOR prod.sh
#
# start.sh sources this file, then execs venv-py39/bin/pserve production.ini.
# (See qa.sh.example for the QA equivalent.)

# --- App / server ------------------------------------------------------------
export INI_FILE="/data/www/SGDBackend-Nex2/production.ini"
export SERVER_NAME="www.yeastgenome.org"
export PREVIEW_SERVER="https://preview.yeastgenome.org"
export PREVIEW_URL="https://preview.yeastgenome.org"
export ABC_API_ROOT_URL="https://<abc-api-host>"
export DEFAULT_USER="CHANGEME"
export CACHE_URLS="https://www.yeastgenome.org"

# --- Database (secret) -------------------------------------------------------
export NEX2_URI="postgresql://USER:PASSWORD@HOST:5432/DBNAME"
export BATTER_URI="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# --- Elasticsearch -----------------------------------------------------------
export ES_URI="http://<es-host>:9200"
export WRITE_ES_URI="http://<es-host>:9200"
export ES_INDEX_NAME="searchable_items_aws"

# --- Redis -------------------------------------------------------------------
export REDIS_READ_HOST="<redis-read-host>"
export REDIS_WRITE_HOST="<redis-write-host>"
export REDIS_PORT="6379"

# --- AWS / S3 (secret) -------------------------------------------------------
export AWS_ACCESS_KEY_ID="CHANGEME"
export AWS_SECRET_ACCESS_KEY="CHANGEME"
export AWS_REGION="us-west-2"
export AWS_DEFAULT_REGION="us-west-2"
export S3_ACCESS_KEY="CHANGEME"
export S3_SECRET_KEY="CHANGEME"
export S3_BUCKET="<s3-bucket>"
export ARCHIVE_S3_BUCKET="<archive-s3-bucket>"
export EXPRESSION_S3_BUCKET="<expression-s3-bucket>"

# --- SNS / email -------------------------------------------------------------
export SNS_REGION="us-west-2"
export SNS_TOPIC_ARN="arn:aws:sns:us-west-2:<acct>:<topic>"
export EMAIL_FROM="CHANGEME"
export EMAIL_TO="CHANGEME"

# --- Third-party auth / integrations (secret) --------------------------------
export GOOGLE_CLIENT_ID="CHANGEME"
export GOOGLE_CAPTCHA_SECRET="CHANGEME"
export PUSHER_APP_ID="CHANGEME"
export PUSHER_KEY="CHANGEME"
export PUSHER_SECRET="CHANGEME"
export LOGIN_EMAIL="CHANGEME"
export LOGIN_PASSWORD="CHANGEME"

# --- Files / logging ---------------------------------------------------------
export INPUT_FILE_NAME=""
export LOG_LEVEL="INFO"
export LOG_FILE="/var/log/sgd-backend/app.log"
export SCRIPT_LOG_FILE="/var/log/sgd-backend/script.log"
export WORKER_LOG_FILE="/var/log/sgd-backend/worker.log"
